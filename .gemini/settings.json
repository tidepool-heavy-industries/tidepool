{
  "mcpServers": {
    "exomonad": {
      "httpUrl": "http://localhost:7432/agents/dev/structured-errors/mcp"
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "exomonad hook before-tool --runtime gemini"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "exomonad hook after-agent --runtime gemini"
          }
        ]
      }
    ]
  }
}